# Copy this file to .env and fill in the real values (never commit .env)

# Django — generate one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me
DEBUG=True

# Postgres (Neon / Supabase / Vercel Postgres connection string)
# Leave unset locally to fall back to a local sqlite db.
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Cloudinary — from your Cloudinary dashboard (Account Details)
# Leave unset locally to store uploads in ./media instead.
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
